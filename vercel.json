{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static-build"
    },
    {
      "src": "css/**",
      "use": "@vercel/static-build"
    },
    {
      "src": "js/**",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/admins",
      "dest": "/admins.html"
    },
    {
      "src": "/admin-add",
      "dest": "/admin-add.html"
    },
    {
      "src": "/settings",
      "dest": "/settings.html"
    },
    {
      "src": "/admin-profile",
      "dest": "/admin-profile.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://admin-main-backend.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": true
}